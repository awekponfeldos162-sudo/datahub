# ===== SERVEUR =====
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:5000
APP_NAME=DATAhub

# ===== BASE DE DONNÉES =====
DATABASE_URL="postgresql://datahub_user:VOTRE_MOT_DE_PASSE@localhost:5432/datahub?schema=public"
SHADOW_DATABASE_URL="postgresql://postgres:VOTRE_MOT_DE_PASSE_POSTGRES@localhost:5432/datahub_shadow?schema=public"

# ===== REDIS =====
REDIS_URL=redis://localhost:6379

# ===== JWT =====
JWT_SECRET=changez-ce-secret-minimum-32-caracteres-en-production
JWT_REFRESH_SECRET=changez-ce-refresh-secret-minimum-32-caracteres!!
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ===== CHIFFREMENT AES-256 (64 hex chars = 32 bytes) =====
ENCRYPTION_KEY=generez-avec-openssl-rand-hex-32

# ===== GOOGLE OAUTH =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== FACEBOOK OAUTH =====
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ===== YOUTUBE API =====
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ===== INSTAGRAM API =====
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# ===== TIKTOK API =====
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ===== SNAPCHAT API =====
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# ===== EMAIL SMTP Gmail =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=noreply@datahub.app

# ===== AWS S3 =====
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
AWS_S3_BUCKET=datahub-reports

# ===== FLUTTERWAVE =====
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# ===== CINETPAY (marché francophone Afrique de l'Ouest) =====
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# ===== SENTRY =====
SENTRY_DSN=
